// RexOS fastfetch — shows the RexOS logo + identity (not Arch).
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/rexos-logo.txt",
        "type": "file",
        "color": { "1": "38;2;20;184;196", "2": "38;2;107;114;128" }
    },
    "display": { "separator": "  " },
    "modules": [
        "break",
        { "type": "custom", "format": "[38;2;20;184;196m  R E X O S[0m" },
        "break",
        { "type": "os",       "key": "  OS",     "keyColor": "38;2;20;184;196", "format": "RexOS {12}" },
        { "type": "kernel",   "key": "  Kernel", "keyColor": "38;2;20;184;196" },
        { "type": "uptime",   "key": "  Uptime", "keyColor": "38;2;20;184;196" },
        { "type": "packages", "key": "  Pkgs",   "keyColor": "38;2;20;184;196" },
        { "type": "wm",       "key": "  Shell",  "keyColor": "38;2;20;184;196", "format": "RexOS Shell" },
        { "type": "terminal", "key": "  Term",   "keyColor": "38;2;20;184;196" },
        { "type": "memory",   "key": "  RAM",    "keyColor": "38;2;20;184;196" },
        "break",
        { "type": "colors", "paddingLeft": 2, "symbol": "circle" }
    ]
}
